APP_NAME=Project Aether API
ENVIRONMENT=development
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000

USE_EXTERNAL_STORES=true
ENABLE_BACKGROUND_AGENTS=true
ENABLE_API_KEY_AUTH=false
SERVICE_API_KEY=change-me
ENABLE_RATE_LIMIT=true
RATE_LIMIT_PER_MINUTE=120
DEBUG_TRACING=true
DEBUG_TRACE_LIMIT=100
POSTGRES_DSN=postgresql://aether:aether@localhost:5432/aether
QDRANT_URL=http://localhost:6333
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
REDIS_URL=redis://localhost:6379/0

INFERENCE_PROVIDER=llm
INFERENCE_MODEL=cydonia-v4.1-ms3.2-magnum-diamond-24b-i1
INFERENCE_BASE_URL=http://localhost:1234/v1/
INFERENCE_API_KEY=
INFERENCE_TIMEOUT_SECONDS=30
INFERENCE_MAX_RETRIES=2
INFERENCE_FAILOVER_ENABLED=false
FALLBACK_INFERENCE_MODEL=cydonia-v4.1-ms3.2-magnum-diamond-24b-i1
FALLBACK_INFERENCE_BASE_URL=http://localhost:1234/v1/
FALLBACK_INFERENCE_API_KEY=me

ANALYSIS_PROVIDER=llm
ANALYSIS_MODEL=cydonia-v4.1-ms3.2-magnum-diamond-24b-i1
ANALYSIS_BASE_URL=http://localhost:1234/v1/
ANALYSIS_API_KEY=me
ANALYSIS_TIMEOUT_SECONDS=8
ANALYSIS_MAX_RETRIES=1

EMBEDDING_PROVIDER=openai_compatible
EMBEDDING_MODEL=text-embedding-embeddinggemma-300m-qat
EMBEDDING_BASE_URL=http://localhost:1234/v1
EMBEDDING_API_KEY=
EMBEDDING_DIMENSIONS=768
EMBEDDING_TIMEOUT_SECONDS=10
